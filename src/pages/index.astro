			rel="stylesheet"
		/>
		<title>Welcome</title>
	</head>

	<body class="bg-[#f3efdb] h-screen">
		<div class="relative h-screen overflow-hidden">
			<!-- background image -->
			<div class="absolute inset-0 bg-hero1 bg-cover bg-center bg-no-repeat"></div>

			<!-- dark tint -->
			<div class="absolute inset-0 bg-stone-950/20"></div>

			<!-- layered animated static / noise -->
			<div class="noise-overlay absolute inset-0 pointer-events-none"></div>
			<div class="noise-overlay-2 absolute inset-0 pointer-events-none"></div>

			<!-- optional scanlines -->
			<div class="scanlines absolute inset-0 pointer-events-none"></div>

			<!-- content -->
			<div class="relative z-10 flex h-full flex-col items-center justify-center gap-1">
				<img class="indexlogo" src="/images/ReKatLogo.png" alt="ReWorxZ Design logo" />

				<button id="page" class="button" data-text="Awesome">
					<span class="actual-text">努力は夢中に勝てない。</span>
					<span aria-hidden="true" class="hover-text">努力は夢中に勝てない。</span>
				</button>
			</div>
		</div>

		<script>
			document.getElementById('page').onclick = function () {
				location.href = '/about';
			};
		</script>
	</body>
</html>